{"author":"FISCO BCOS Supply Chain Finance Team","details":"物流操作合约 管理物流委派单的高级操作，包括批量处理、轨迹追踪等 依赖于 LogisticsCore 合约 栈溢出防护： - 使用 Struct 封装参数 - 使用 calldata 传参 - 批量操作限制","kind":"dev","methods":{"batchAssignCarrier((string[],bytes32[]))":{"details":"批量指派承运方","params":{"input":"批量指派参数"},"returns":{"success":"是否成功"}},"batchUpdateStatus((string[],uint8[]))":{"details":"批量更新状态","params":{"input":"批量状态更新参数"},"returns":{"success":"是否成功"}},"createLogisticsDelegate(string[],uint256[],bytes32[])":{"details":"创建物流委派单（运维代理接口，数组参数解决Stack too deep）","params":{"bytesParams":"[0]=ownerHash, [1]=carrierHash, [2]=sourceWhHash, [3]=targetWhHash","stringParams":"[0]=voucherNo, [1]=receiptId, [2]=unit","uintParams":"[0]=businessScene, [1]=transportQuantity, [2]=validUntil"},"returns":{"success":"是否成功"}},"getLogisticsTrack(string)":{"details":"获取物流轨迹（简化版，实际需要链下存储完整轨迹）","params":{"voucherNo":"委派单编号"},"returns":{"_0":"状态数组"}},"isCarrierAuthorized(string,bytes32)":{"details":"验证承运方是否有权操作","params":{"carrierHash":"承运方哈希","voucherNo":"委派单编号"},"returns":{"isAuthorized":"是否授权"}},"validateLogisticsDelegate(string)":{"details":"验证物流委派单是否有效","params":{"voucherNo":"委派单编号"},"returns":{"isValid":"是否有效"}}},"title":"LogisticsOps","version":1}