{"author":"FISCO BCOS Supply Chain Finance Team","details":"应收款还款管理合约 管理应收款的还款操作，包括还款记录、债务抵消等 依赖于 ReceivableCore 合约","kind":"dev","methods":{"batchRecordRepayment(string[],uint256[],string[])":{"details":"批量记录还款","params":{"amounts":"还款金额数组","paymentMethods":"还款方式数组","receivableIds":"应收款ID数组"},"returns":{"success":"是否成功"}},"getLatestRepayment(string)":{"details":"获取最新还款记录","params":{"receivableId":"应收款ID"}},"getOffsetRecordCount()":{"details":"获取抵消记录数量","returns":{"_0":"记录数量"}},"getOffsetRecords(uint256,uint256)":{"details":"获取抵消记录","params":{"limit":"数量限制","offset":"起始索引"},"returns":{"_0":"抵消记录数组"}},"getRepaymentRecordCount(string)":{"details":"获取还款记录数量","params":{"receivableId":"应收款ID"},"returns":{"_0":"记录数量"}},"getRepaymentRecords(string,uint256,uint256)":{"details":"获取还款记录（分页）","params":{"limit":"数量限制","offset":"起始索引","receivableId":"应收款ID"},"returns":{"_0":"还款记录数组"}},"getTotalRepaid(string)":{"details":"获取总还款额","params":{"receivableId":"应收款ID"}},"offsetDebtWithCollateral(string,string,uint256,string)":{"details":"债务抵消","params":{"offsetAmount":"抵消金额","reason":"抵消原因","sourceReceivableId":"源应收款ID（付款方）","targetReceivableId":"目标应收款ID（收款方）"},"returns":{"success":"是否成功"}},"recordFullRepayment(string,uint256)":{"details":"记录现金还款（直接结清）","params":{"amount":"还款金额","receivableId":"应收款ID"},"returns":{"success":"是否成功"}},"recordRepayment(string,uint256,string)":{"details":"记录还款","params":{"amount":"还款金额","paymentMethod":"还款方式","receivableId":"应收款ID"},"returns":{"success":"是否成功"}}},"title":"ReceivableRepayment","version":1}