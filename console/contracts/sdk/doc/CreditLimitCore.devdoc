{"author":"FISCO BCOS Supply Chain Finance Team","details":"信用额度核心合约 管理企业信用额度的核心操作，包括额度管理、事件上报等 遵循数据上链规范： - 明文上链：creditLimit, creditScore, lastUpdateTime - 哈希化上链：eventDataHash","kind":"dev","methods":{"adjustUsedCredit(address,int256)":{"details":"调整已用额度（不改变总额度）","params":{"adjustment":"调整金额（正负）","enterpriseAddress":"企业地址"},"returns":{"success":"是否成功"}},"batchSetCreditLimit(address[],uint256[])":{"details":"批量设置授信额度","params":{"enterprises":"企业地址数组","limits":"额度数组"},"returns":{"success":"是否成功"}},"checkCreditLimit(address,uint256)":{"details":"检查可用额度","params":{"amount":"检查金额","enterpriseAddress":"企业地址"},"returns":{"hasLimit":"是否有足够额度"}},"getCreditEventCount(address)":{"details":"获取信用事件数量","params":{"enterpriseAddress":"企业地址"},"returns":{"_0":"count 事件数量"}},"getCreditEvents(address,uint256,uint256)":{"details":"获取信用事件（分页）","params":{"enterpriseAddress":"企业地址","limit":"数量限制","offset":"起始索引"},"returns":{"_0":"events 事件数组"}},"getCreditInfo(address)":{"details":"获取信用额度信息","params":{"enterpriseAddress":"企业地址"},"returns":{"_enterpriseAddress":"企业地址"}},"hasCreditRecord(address)":{"details":"检查企业是否有信用记录","params":{"enterpriseAddress":"企业地址"},"returns":{"_0":"hasRecord 是否有记录"}},"releaseCredit(address,uint256,string)":{"details":"释放额度","params":{"amount":"释放金额","enterpriseAddress":"企业地址","operationType":"操作类型"},"returns":{"success":"是否成功"}},"reportCreditEvent(address,uint8,int256,bytes32)":{"details":"上报信用事件","params":{"enterpriseAddress":"企业地址","eventDataHash":"事件数据哈希","eventType":"事件类型","impact":"影响值"},"returns":{"success":"是否成功"}},"setCreditLimit(address,uint256)":{"details":"设置授信额度","params":{"enterpriseAddress":"企业地址","newLimit":"新授信额度"},"returns":{"success":"是否成功"}},"useCredit(address,uint256,string)":{"details":"使用额度","params":{"amount":"使用金额","enterpriseAddress":"企业地址","operationType":"操作类型"},"returns":{"success":"是否成功"}}},"title":"CreditLimitCore","version":1}