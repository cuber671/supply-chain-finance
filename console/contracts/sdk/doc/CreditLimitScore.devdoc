{"author":"FISCO BCOS Supply Chain Finance Team","details":"信用评分合约 管理企业信用评分计算、评分历史等","kind":"dev","methods":{"adjustScore(address,uint256,string)":{"details":"调整信用评分（手动）","params":{"enterpriseAddress":"企业地址","newScore":"新评分","reason":"调整原因"},"returns":{"success":"是否成功"}},"batchCalculateScore(address[],(uint256,uint256,uint256,uint256,uint256)[])":{"details":"批量计算评分","params":{"enterprises":"企业地址数组","factorsArray":"评分因素数组"},"returns":{"success":"是否成功"}},"calculateScore(address,(uint256,uint256,uint256,uint256,uint256))":{"details":"计算信用评分","params":{"enterpriseAddress":"企业地址","factors":"评分因素"},"returns":{"score":"计算后的评分"}},"checkScoreLevel(address,uint256)":{"details":"检查评分是否在指定等级","params":{"enterpriseAddress":"企业地址","minScore":"最低评分"},"returns":{"_0":"isEligible 是否符合"}},"getCurrentScore(address)":{"details":"获取当前评分","params":{"enterpriseAddress":"企业地址"},"returns":{"score":"当前评分"}},"getLatestScore(address)":{"details":"获取最新评分记录","params":{"enterpriseAddress":"企业地址"},"returns":{"calculationTime":"计算时间","previousScore":"上次评分","score":"最新评分"}},"getScoreHistory(address,uint256,uint256)":{"details":"获取评分历史（分页）","params":{"enterpriseAddress":"企业地址","limit":"数量限制","offset":"起始索引"},"returns":{"_0":"history 评分历史数组"}},"getScoreHistoryCount(address)":{"details":"获取评分历史数量","params":{"enterpriseAddress":"企业地址"},"returns":{"_0":"count 历史记录数量"}},"getScoreLevel(uint256)":{"details":"获取评分等级","params":{"score":"评分"},"returns":{"level":"等级字符串"}}},"title":"CreditLimitScore","version":1}