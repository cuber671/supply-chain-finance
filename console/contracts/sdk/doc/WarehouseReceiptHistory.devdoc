{"author":"FISCO BCOS Supply Chain Finance Team","details":"仓单历史记录合约 记录仓单的所有变更操作，确保数据可追溯","kind":"dev","methods":{"batchRecordHistory(string[],uint8[],bytes32[],string[])":{"details":"批量记录变更","params":{"descriptions":"描述数组","operationTypes":"操作类型数组","operatorHashes":"操作者哈希数组","receiptIds":"仓单ID数组"},"returns":{"success":"是否成功"}},"getGlobalHistory(uint256,uint256)":{"details":"获取全局历史记录","params":{"limit":"数量限制","offset":"起始索引"},"returns":{"_0":"历史记录数组"}},"getHistory(string,uint256,uint256)":{"details":"获取仓单历史记录（分页）","params":{"limit":"数量限制","offset":"起始索引","receiptId":"仓单ID"},"returns":{"_0":"历史记录数组"}},"getHistoryByIndex(string,uint256)":{"details":"获取单条历史记录","params":{"index":"记录索引","receiptId":"仓单ID"}},"getHistoryByOperationType(string,uint8)":{"details":"根据操作类型查询历史","params":{"operationType":"操作类型","receiptId":"仓单ID"},"returns":{"_0":"符合条件的历史记录"}},"getHistoryCount(string)":{"details":"获取仓单历史记录数量","params":{"receiptId":"仓单ID"},"returns":{"_0":"记录数量"}},"getLatestHistory(string)":{"details":"获取最新历史记录","params":{"receiptId":"仓单ID"}},"recordHistory(string,uint8,bytes32,string)":{"details":"记录仓单变更","params":{"description":"操作描述","operationType":"操作类型","operatorHash":"操作者哈希","receiptId":"仓单ID"},"returns":{"recordId":"记录ID"}},"recordHistoryWithDetail(string,uint8,bytes32,string,string,bytes32)":{"details":"记录带详情的变更","params":{"afterValue":"变更后值","beforeValue":"变更前值","operationType":"操作类型","operatorHash":"操作者哈希","receiptId":"仓单ID","relatedHash":"关联哈希"},"returns":{"recordId":"记录ID"}}},"title":"WarehouseReceiptHistory","version":1}