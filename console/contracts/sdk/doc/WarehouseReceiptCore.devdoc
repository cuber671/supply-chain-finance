{"author":"FISCO BCOS Supply Chain Finance Team","details":"仓单核心合约 管理仓单的全生命周期，包括创建、转移、锁定、解锁等核心操作 遵循数据上链规范： - 明文上链：receiptId, weight, unit, quantity, status, storageDate, expiryDate, frozen - 哈希化上链：ownerHash, warehouseHash - 全摘要存证：goodsDetailHash, locationPhotoHash, contractHash 栈溢出防护： - 使用 Struct 封装参数 - 使用 calldata 传参 - 批量操作限制","kind":"dev","methods":{"burnReceipt(string,bytes32)":{"details":"核销仓单（提货出库）","params":{"receiptId":"仓单ID","signatureHash":"签名哈希（预留参数，用于未来签名验证）"},"returns":{"success":"是否成功"}},"canOperate(string)":{"details":"检查仓单是否可以操作","params":{"receiptId":"仓单ID"},"returns":{"_0":"canOperate 是否可以操作"}},"cancelReceipt(string,string)":{"details":"注销仓单","params":{"reason":"注销原因","receiptId":"仓单ID"},"returns":{"success":"是否成功"}},"exists(string)":{"details":"检查仓单是否存在","params":{"receiptId":"仓单ID"},"returns":{"_0":"是否存在"}},"getOwnerHash(string)":{"details":"获取仓单所有者哈希","params":{"receiptId":"仓单ID"},"returns":{"ownerHash":"仓单所有者哈希"}},"getReceipt(string)":{"details":"获取仓单完整信息","params":{"receiptId":"仓单ID"},"returns":{"_receiptId":"仓单ID","ownerHash":"货主哈希","warehouseHash":"仓库哈希"}},"getReceiptIdsByOwner(address,uint256,uint256)":{"details":"批量获取仓单ID列表","params":{"limit":"数量限制","offset":"起始索引","owner":"所有者地址"},"returns":{"_0":"仓单ID列表"}},"getReceiptStatus(string)":{"details":"获取仓单状态","params":{"receiptId":"仓单ID"},"returns":{"status":"仓单状态"}},"getReceiptWeight(string)":{"details":"获取仓单重量","params":{"receiptId":"仓单ID"},"returns":{"weight":"仓单重量"}},"isPledgedByReceiptId(string)":{"details":"检查仓单是否已质押","params":{"receiptId":"仓单ID"},"returns":{"isPledged":"是否已质押"}},"issueReceipt((string,bytes32,bytes32,bytes32,bytes32,bytes32,uint256,string,uint256,uint256,uint256))":{"details":"开立仓单","params":{"input":"仓单创建参数"},"returns":{"success":"是否成功"}},"lockReceipt(string)":{"details":"锁定仓单（金融机构操作）","params":{"receiptId":"仓单ID"},"returns":{"success":"是否成功"}},"mergeReceipts((string[],string,bytes32,string,uint256))":{"details":"合并仓单（链上存证版）","params":{"input":"合并参数"},"returns":{"success":"是否成功 注意：此函数仅在链上记录合并事件，实际合并由应用层处理"}},"restoreFromTransit(string)":{"details":"从物流转运中状态恢复到在库状态（部分交付确认时调用）","params":{"receiptId":"仓单ID"},"returns":{"success":"是否成功"}},"setInTransit(string)":{"details":"设置仓单为物流转运中状态（物流提货确认时调用）","params":{"receiptId":"仓单ID"},"returns":{"success":"是否成功"}},"splitReceipt((string,string[],uint256[],bytes32[],bytes32[],string))":{"details":"拆分仓单（链上存证版）","params":{"input":"拆分参数"},"returns":{"success":"是否成功 注意：此函数仅在链上记录拆分事件，实际拆分由应用层处理 避免栈溢出问题，采用简化实现"}},"transferReceipt(string,bytes32)":{"details":"转移仓单所有权","params":{"newOwnerHash":"新货主哈希","receiptId":"仓单ID"},"returns":{"success":"是否成功"}},"unlockReceipt(string)":{"details":"解锁仓单","params":{"receiptId":"仓单ID"},"returns":{"success":"是否成功"}},"updateOwner(string,bytes32)":{"details":"更新仓单所有者（供Ops合约调用）","params":{"newOwnerHash":"新货主哈希","receiptId":"仓单ID"},"returns":{"success":"是否成功"}}},"title":"WarehouseReceiptCore","version":1}