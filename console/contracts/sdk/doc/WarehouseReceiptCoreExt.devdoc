{"author":"FISCO BCOS Supply Chain Finance Team","details":"仓单核心合约扩展 - 增加贷款关联 在原有WarehouseReceiptCore基础上，扩展loanId字段关联 用于建立仓单与质押贷款之间的关联关系 设计原则： - 保留原有所有方法和接口 - 仅新增字段和可选的扩展方法 - 原有合约地址保持不变（向后兼容）","kind":"dev","methods":{"getPledgeAmount(string)":{"details":"获取质押金额","params":{"loanId":"贷款编号"},"returns":{"pledgeAmount":"质押金额"}},"getPledgeInfo(string)":{"details":"获取质押信息","params":{"loanId":"贷款编号"},"returns":{"info":"质押信息"}},"getPledgeStatus(string)":{"details":"获取质押状态","params":{"receiptId":"仓单ID"},"returns":{"status":"质押状态: 0=未质押, 1=质押中, 2=已释放"}},"getReceiptLoanId(string)":{"details":"获取仓单关联的贷款ID","params":{"receiptId":"仓单ID"},"returns":{"loanId":"贷款编号"}},"hasActiveLoan(string)":{"details":"检查仓单是否有活跃贷款","params":{"receiptId":"仓单ID"},"returns":{"_0":"hasActiveLoan 是否有活跃贷款"}},"isLoanActive(string)":{"details":"检查贷款是否活跃","params":{"loanId":"贷款编号"},"returns":{"isActive":"是否活跃"}},"isLoanMatchedWithReceipt(string,string)":{"details":"验证贷款是否与仓单匹配","params":{"loanId":"贷款编号","receiptId":"仓单ID"},"returns":{"isMatched":"是否匹配"}},"isReceiptPledged(string)":{"details":"检查仓单是否已质押","params":{"receiptId":"仓单ID"},"returns":{"isPledged":"是否已质押"}},"releaseReceiptLoanId(string)":{"details":"解除仓单-贷款关联（结清时调用）","params":{"receiptId":"仓单ID"},"returns":{"success":"是否成功"}},"setReceiptLoanId(string,string,uint256)":{"details":"设置仓单-贷款关联","params":{"loanId":"贷款编号","pledgeAmount":"质押金额","receiptId":"仓单ID"},"returns":{"success":"是否成功"}},"updatePledgeAmount(string,uint256)":{"details":"更新质押信息","params":{"loanId":"贷款编号","newAmount":"新质押金额"},"returns":{"success":"是否成功"}},"updateReceiptLoanId(string,string)":{"details":"更新仓单-贷款关联","params":{"newLoanId":"新贷款编号","receiptId":"仓单ID"},"returns":{"success":"是否成功"}}},"stateVariables":{"loanPledgeInfos":{"details":"贷款ID -> 质押信息 映射"},"receiptExists":{"details":"仓单是否存在（外部检查）"},"receiptLoanIds":{"details":"仓单ID -> 贷款ID 映射"}},"title":"WarehouseReceiptCoreExt","version":1}