{"author":"FISCO BCOS Supply Chain Finance Team","details":"应收款核心合约 管理应收款的全生命周期，包括创建、确认、调整等核心操作 遵循数据上链规范： - 明文上链：receivableId, initialAmount, balanceUnpaid, dueDate, status - 哈希化上链：buyerSellerPairHash - 全摘要存证：invoiceHash, contractHash, goodsDetailHash 栈溢出防护： - 使用 Struct 封装参数 - 使用 calldata 传参 - 批量操作限制","kind":"dev","methods":{"adjustReceivable((string,uint256,string))":{"details":"调整应收款金额","params":{"input":"调整参数"},"returns":{"success":"是否成功"}},"checkAndUpdateOverdue(string)":{"details":"检查并更新逾期状态","params":{"receivableId":"应收款ID"},"returns":{"isOverdue":"是否逾期"}},"confirmReceivable(string)":{"details":"确认应收款","params":{"receivableId":"应收款ID"},"returns":{"success":"是否成功"}},"createReceivable((string,uint256,uint256,bytes32,bytes32,bytes32,bytes32,uint8))":{"details":"创建应收款","params":{"input":"应收款创建参数"},"returns":{"success":"是否成功"}},"exists(string)":{"details":"检查应收款是否存在","params":{"receivableId":"应收款ID"},"returns":{"_0":"是否存在"}},"financeReceivable(string,string,uint256)":{"details":"发起融资","params":{"amount":"融资金额","financialInstitution":"金融机构地址","receivableId":"应收款ID"},"returns":{"success":"是否成功"}},"getBalanceUnpaid(string)":{"details":"获取应收款余额","params":{"receivableId":"应收款ID"},"returns":{"balanceUnpaid":"剩余未还金额"}},"getDebtorHash(string)":{"details":"获取债务人哈希","params":{"receivableId":"应收款ID"},"returns":{"debtorHash":"债务人哈希"}},"getReceivable(string)":{"details":"获取应收款完整信息","params":{"receivableId":"应收款ID"},"returns":{"info":"应收款完整信息"}},"getReceivableCore(string)":{"details":"获取应收款核心信息","params":{"receivableId":"应收款ID"},"returns":{"_receiptId":"应收款ID"}},"getReceivableStatus(string)":{"details":"获取应收款状态","params":{"receivableId":"应收款ID"},"returns":{"status":"应收款状态"}},"getReceivablesByPair(bytes32)":{"details":"获取买卖对关联的应收款","params":{"buyerSellerPairHash":"买卖对哈希"},"returns":{"_0":"应收款ID列表"}},"isValid(string)":{"details":"检查应收款是否有效","params":{"receivableId":"应收款ID"},"returns":{"_0":"是否有效"}},"settleReceivable(string)":{"details":"结清应收款","params":{"receivableId":"应收款ID"},"returns":{"success":"是否成功"}},"updateBalance(string,uint256,bool)":{"details":"更新应收款余额","params":{"amount":"还款金额","isFull":"是否结清","receivableId":"应收款ID"},"returns":{"success":"是否成功"}},"updateStatus(string,uint8)":{"details":"更新状态","params":{"newStatus":"新状态","receivableId":"应收款ID"},"returns":{"success":"是否成功"}}},"title":"ReceivableCore","version":1}