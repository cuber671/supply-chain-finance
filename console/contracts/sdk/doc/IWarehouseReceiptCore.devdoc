{"author":"FISCO BCOS Supply Chain Finance Team","details":"仓单核心合约接口 用于跨合约调用，定义仓单核心业务操作的接口","kind":"dev","methods":{"canOperate(string)":{"details":"检查仓单是否可以操作","params":{"receiptId":"仓单ID"},"returns":{"canOperate":"是否可以操作"}},"exists(string)":{"details":"检查仓单是否存在","params":{"receiptId":"仓单ID"},"returns":{"exists":"是否存在"}},"getOwnerHash(string)":{"details":"获取仓单所有者哈希","params":{"receiptId":"仓单ID"},"returns":{"ownerHash":"仓单所有者哈希"}},"getReceipt(string)":{"details":"获取仓单详情","params":{"receiptId":"仓单ID"},"returns":{"_receiptId":"仓单ID","ownerHash":"所有者哈希","quantity":"数量","status":"状态","unit":"单位","warehouseHash":"仓库哈希","weight":"重量"}},"getReceiptStatus(string)":{"details":"获取仓单状态","params":{"receiptId":"仓单ID"},"returns":{"status":"仓单状态 (0=None, 1=InStorage, 6=Pledged)"}},"getReceiptWeight(string)":{"details":"获取仓单重量","params":{"receiptId":"仓单ID"},"returns":{"weight":"仓单重量"}},"isPledgedByReceiptId(string)":{"details":"检查仓单是否已质押（Pledged）","params":{"receiptId":"仓单ID"},"returns":{"isPledged":"是否已质押"}},"mergeReceipts((string[],string,bytes32,string,uint256))":{"details":"合并仓单","params":{"input":"合并参数"},"returns":{"success":"是否成功"}},"splitReceipt((string,string[],uint256[],bytes32[],bytes32[],string))":{"details":"拆分仓单","params":{"input":"拆分参数"},"returns":{"success":"是否成功"}},"updateOwner(string,bytes32)":{"details":"更新仓单所有者（供Ops合约调用）","params":{"newOwnerHash":"新货主哈希","receiptId":"仓单ID"},"returns":{"success":"是否成功"}}},"title":"IWarehouseReceiptCore","version":1}