{"author":"FISCO BCOS Supply Chain Finance Team","details":"仓单操作合约 管理仓单的高级操作，包括拆分、合并、背书等 依赖于 WarehouseReceiptCore 合约 栈溢出防护： - 使用 Struct 封装参数 - 使用 calldata 传参 - 批量操作限制","kind":"dev","methods":{"batchLaunchEndorsement((string,bytes32,bytes32,string)[])":{"details":"批量发起背书","params":{"inputs":"背书参数数组"},"returns":{"success":"是否成功"}},"batchSplitReceipt((string,string[],uint256[],bytes32[],bytes32[],string)[])":{"details":"批量拆分仓单","params":{"inputs":"拆分参数数组"},"returns":{"success":"是否成功"}},"confirmEndorsement(string,bytes32,bytes32)":{"details":"确认背书","params":{"fromHash":"原持有人哈希","receiptId":"仓单ID","toHash":"新持有人哈希"},"returns":{"success":"是否成功"}},"launchEndorsement((string,bytes32,bytes32,string))":{"details":"发起背书","params":{"input":"背书参数"},"returns":{"success":"是否成功"}},"mergeReceipts((string[],string,bytes32,string))":{"details":"合并仓单","params":{"input":"合并参数"},"returns":{"success":"是否成功"}},"rejectEndorsement(string,bytes32,string)":{"details":"拒绝背书","params":{"fromHash":"原持有人哈希","reason":"拒绝原因","receiptId":"仓单ID"},"returns":{"success":"是否成功"}},"splitReceipt((string,string[],uint256[],bytes32[],bytes32[],string))":{"details":"拆分仓单","params":{"input":"拆分参数"},"returns":{"success":"是否成功"}}},"title":"WarehouseReceiptOps","version":1}