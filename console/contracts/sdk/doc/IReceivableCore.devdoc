{"author":"FISCO BCOS Supply Chain Finance Team","details":"应收款核心合约接口 用于跨合约调用，定义应收款核心业务操作的接口","kind":"dev","methods":{"exists(string)":{"details":"检查应收款是否存在","params":{"receivableId":"应收款ID"},"returns":{"exists":"是否存在"}},"getBalanceUnpaid(string)":{"details":"获取应收款余额","params":{"receivableId":"应收款ID"},"returns":{"balanceUnpaid":"剩余未还金额"}},"getDebtorHash(string)":{"details":"获取债务人哈希","params":{"receivableId":"应收款ID"},"returns":{"debtorHash":"债务人哈希"}},"getReceivableStatus(string)":{"details":"获取应收款状态","params":{"receivableId":"应收款ID"},"returns":{"status":"应收款状态"}},"settleReceivable(string)":{"details":"结清应收款","params":{"receivableId":"应收款ID"},"returns":{"success":"是否成功"}},"updateBalance(string,uint256,bool)":{"details":"更新应收款余额","params":{"amount":"还款金额","isFull":"是否结清","receivableId":"应收款ID"},"returns":{"success":"是否成功"}}},"title":"IReceivableCore","version":1}