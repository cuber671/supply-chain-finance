{"author":"FISCO BCOS Supply Chain Finance Team","details":"物流核心合约接口 用于跨合约调用，定义物流委派单核心业务操作的接口","kind":"dev","methods":{"arriveAndAddQuantity(string,string,uint256)":{"details":"到货时增量入库","params":{"quantity":"增量数量","targetReceiptId":"目标仓单ID","voucherNo":"委派单编号"},"returns":{"success":"是否成功"}},"arriveAndCreateReceipt(string,string,uint256,string,bytes32,bytes32)":{"details":"到货时生成新仓单","params":{"newReceiptId":"新仓单ID","ownerHash":"货主哈希","unit":"计量单位","voucherNo":"委派单编号","warehouseHash":"仓库哈希","weight":"新仓单重量"},"returns":{"success":"是否成功"}},"assignCarrier(string,bytes32)":{"details":"指派承运方","params":{"carrierHash":"承运方哈希","voucherNo":"委派单编号"},"returns":{"success":"是否成功"}},"confirmDelivery(string,uint8,string)":{"details":"确认交付","params":{"action":"到货处理动作","targetReceiptId":"目标仓单ID（增量入库时使用）","voucherNo":"委派单编号"},"returns":{"success":"是否成功"}},"createLogisticsDelegate(string[],uint256[],bytes32[])":{"details":"创建物流委派单（数组参数解决Stack too deep）","params":{"bytesParams":"[0]=ownerHash, [1]=carrierHash, [2]=sourceWhHash, [3]=targetWhHash","stringParams":"[0]=voucherNo, [1]=receiptId, [2]=unit","uintParams":"[0]=businessScene, [1]=transportQuantity, [2]=validUntil"},"returns":{"success":"是否成功"}},"exists(string)":{"details":"检查委派单是否存在","params":{"voucherNo":"委派单编号"},"returns":{"exists":"是否存在"}},"getOwnerHash(string)":{"details":"获取货主哈希","params":{"voucherNo":"委派单编号"},"returns":{"ownerHash":"货主哈希"}},"getStatus(string)":{"details":"获取委派单状态","params":{"voucherNo":"委派单编号"},"returns":{"status":"委派单状态"}},"invalidate(string)":{"details":"使委派单失效","params":{"voucherNo":"委派单编号"},"returns":{"success":"是否成功"}},"isValid(string)":{"details":"检查委派单是否有效","params":{"voucherNo":"委派单编号"},"returns":{"isValid":"是否有效"}},"pickup(string,uint256)":{"details":"提货时扣减仓单重量","params":{"quantity":"扣减数量","voucherNo":"委派单编号"},"returns":{"success":"是否成功"}},"updateStatus(string,uint8)":{"details":"更新物流状态","params":{"newStatus":"新状态","voucherNo":"委派单编号"},"returns":{"success":"是否成功"}}},"title":"ILogisticsCore","version":1}