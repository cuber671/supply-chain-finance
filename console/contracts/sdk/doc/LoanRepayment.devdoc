{"author":"FISCO BCOS Supply Chain Finance Team","details":"贷款还款合约 处理质押贷款的各种还款方式，包括： - 现金还款 (Cash) - 仓单抵债 (ReceiptOffset) - 应收账款抵债 (ReceivableOffset) - 质押物处置 (CollateralDisposal) - 部分还款 (Partial)","kind":"dev","methods":{"confirmRepayment(string,uint256)":{"details":"确认还款","params":{"confirmedAmount":"确认金额","repaymentNo":"还款编号"},"returns":{"success":"是否成功"}},"exists(string)":{"details":"检查还款是否存在","params":{"repaymentNo":"还款编号"},"returns":{"_0":"exists 是否存在"}},"getReceiptOffset(string)":{"details":"获取仓单抵债记录","params":{"repaymentNo":"还款编号"},"returns":{"record":"仓单抵债记录"}},"getReceivableOffset(string)":{"details":"获取应收账款抵债记录","params":{"repaymentNo":"还款编号"},"returns":{"record":"应收账款抵债记录"}},"getRepayment(string)":{"details":"获取还款记录","params":{"repaymentNo":"还款编号"},"returns":{"record":"还款记录"}},"getRepaymentCount(string)":{"details":"获取还款记录数量","params":{"loanNo":"贷款编号"},"returns":{"count":"还款记录数量"}},"getRepaymentTypeName(uint8)":{"details":"获取还款类型名称","params":{"repaymentType":"还款类型"},"returns":{"typeName":"类型名称"}},"getRepaymentsByLoan(string)":{"details":"获取贷款的所有还款记录","params":{"loanNo":"贷款编号"},"returns":{"repaymentNos":"还款编号列表"}},"recordCashRepayment((string,string,uint256,uint256,uint256,bytes32))":{"details":"记录现金还款","params":{"input":"现金还款参数"},"returns":{"success":"是否成功"}},"recordCollateralDisposal(string,string,string,uint256)":{"details":"记录质押物处置","params":{"disposalAmount":"处置金额","disposalMethod":"处置方式","loanNo":"贷款编号","repaymentNo":"还款编号"},"returns":{"success":"是否成功"}},"recordPartialRepayment((string,string,uint256,uint256,uint256,bytes32))":{"details":"记录部分还款","params":{"input":"部分还款参数"},"returns":{"success":"是否成功"}},"recordReceiptOffset((string,string,string,uint256,bytes32))":{"details":"记录仓单抵债","params":{"input":"仓单抵债参数"},"returns":{"success":"是否成功"}},"recordReceivableOffset((string,string,string,uint256,bytes32))":{"details":"记录应收账款抵债","params":{"input":"应收账款抵债参数"},"returns":{"success":"是否成功"}},"rejectRepayment(string,string)":{"details":"拒绝还款","params":{"rejectReason":"拒绝原因","repaymentNo":"还款编号"},"returns":{"success":"是否成功"}}},"title":"LoanRepayment","version":1}