# ============================================================
# FISCO BCOS 供应链金融平台 - Docker Compose 环境变量
# ============================================================
# 注意：此文件包含开发环境配置，请勿提交到Git
# 生产环境请修改 JWT_SECRET 和 ENCRYPTION_KEY

# ==================== 应用配置 ====================
SPRING_PROFILES_ACTIVE=prod
TZ=Asia/Shanghai

# ==================== 镜像版本 ====================
IMAGE_TAG=1.0.0

# ==================== 数据库配置 =====================
DB_NAME=fisco_data
DB_USERNAME=fisco_user
DB_PASSWORD=123456
MYSQL_ROOT_PASSWORD=root_pwd

# ==================== JWT配置 ====================
JWT_SECRET=dev-jwt-secret-key-for-development-only-change-this-in-production-min-256-bits
JWT_EXPIRATION=7200000
JWT_REFRESH_EXPIRATION=604800000

# ==================== 数据加密配置 ====================
ENCRYPTION_KEY=dev-encryption-key-for-development-only

# ==================== FISCO BCOS 区块链配置 ====================
FISCO_ENABLED=true
FISCO_CONFIG_FILE=/app/sdk/config.toml
FISCO_GROUP=group0

# ==================== 合约地址配置 ====================
# 基础库
CONTRACT_LIB_BYTES=0x19a6434154de51c7a7406edf312f01527441b561
CONTRACT_LIB_STRING=0x745d4de0cf93b7d1db8dd8892daf05ac745766ce

# 企业模块
CONTRACT_ENTERPRISE=0xe3fffb217e885578f75e1ac07f1fbff859171fe3
CONTRACT_ENTERPRISE_AUTH=0xc860ab27901b3c2b810165a6096c64d88763617f

# 信用模块
CONTRACT_CREDIT_CORE=0xafcdafa5be0a0e2c34328adf10d893a591b5e774
CONTRACT_CREDIT_SCORE=0x6ea6907f036ff456d2f0f0a858afa9807ff4b788

# 仓单模块
CONTRACT_WAREHOUSE_CORE=0x5e0aa2793a9db58513610d8ff35aa877cee75b8e
CONTRACT_WAREHOUSE_OPS=0xa26565f61568353af17f8ce9beeb8e685140d6fe
CONTRACT_WAREHOUSE_CORE_EXT=0x55b63f96d81f094729af702adfc7af72bd75c54e

# 应收款模块
CONTRACT_RECEIVABLE_CORE=0xb31661caf079ddd45d5ed8af7becc220199fab29
CONTRACT_RECEIVABLE_REPAYMENT=0x1d38f5d0c8c1ae7ed63a2d0ec905b9e9a17e70cf

# 票据模块
CONTRACT_BILL_CORE=0x2af6160e266f763652f433a80b94fc13f4065303
CONTRACT_BILL_OPS=0xa6cdc4fed96bbf8c9c013cc19200b3c8ba95c93e

# 物流模块
CONTRACT_LOGISTICS_CORE=0x3d06c6a1df7d56effec855f813f797a64ea1cee5
CONTRACT_LOGISTICS_OPS=0x525f4e5362d8b15e5d4aa0335b2d153c70aa5eca

# 贷款模块
CONTRACT_LOAN_CORE=0xbf14744175b48ac9a2e1fc4ebc6c0a5f4afd0ad2
CONTRACT_LOAN_REPAYMENT=0xd688eabe4597d2d23180045a4444d0c3450b6ab9

# ==================== Java 调优配置 ====================
# 各服务 JVM 内存配置
JAVA_OPTS_AUTH=-Xms512m -Xmx512m -XX:+UseG1GC
JAVA_OPTS_ENTERPRISE=-Xms512m -Xmx512m -XX:+UseG1GC
JAVA_OPTS_WAREHOUSE=-Xms512m -Xmx512m -XX:+UseG1GC
JAVA_OPTS_LOGISTICS=-Xms512m -Xmx512m -XX:+UseG1GC
JAVA_OPTS_FINANCE=-Xms768m -Xmx768m -XX:+UseG1GC
JAVA_OPTS_CREDIT=-Xms512m -Xmx512m -XX:+UseG1GC
JAVA_OPTS_FISCO_GATEWAY=-Xms1g -Xmx1g -XX:+UseG1GC -XX:MaxGCPauseMillis=200

# ==================== Nginx 配置 ====================
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
