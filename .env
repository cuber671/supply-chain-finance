# ============================================================
# FISCO BCOS 供应链金融平台 - Docker Compose 环境变量
# ============================================================
# 注意：此文件包含开发环境配置，请勿提交到Git
# 生产环境请修改 JWT_SECRET 和 ENCRYPTION_KEY

# ==================== 应用配置 ====================
SPRING_PROFILES_ACTIVE=prod
TZ=Asia/Shanghai

# ==================== 镜像版本 ====================
IMAGE_TAG=1.0.0

# ==================== 数据库配置 =====================
DB_NAME=fisco_data
DB_USERNAME=fisco_user
DB_PASSWORD=123456
MYSQL_ROOT_PASSWORD=root_pwd

# ==================== JWT配置 ====================
JWT_SECRET=dev-jwt-secret-key-for-development-only-change-this-in-production-min-256-bits
JWT_EXPIRATION=7200000
JWT_REFRESH_EXPIRATION=604800000

# ==================== 数据加密配置 ====================
ENCRYPTION_KEY=dev-encryption-key-for-development-only

# ==================== FISCO BCOS 区块链配置 ====================
FISCO_ENABLED=true
FISCO_CONFIG_FILE=/app/sdk/config.toml
FISCO_GROUP=group0

# ==================== 合约地址配置 ====================
# 基础库
CONTRACT_LIB_BYTES=0x19a6434154de51c7a7406edf312f01527441b561
CONTRACT_LIB_STRING=0x745d4de0cf93b7d1db8dd8892daf05ac745766ce

# 企业模块
CONTRACT_ENTERPRISE=0xa35cbba5618b8f1230676d94e6826080c3440115
CONTRACT_ENTERPRISE_AUTH=0xc860ab27901b3c2b810165a6096c64d88763617f

# 信用模块
CONTRACT_CREDIT_CORE=0x4721d1a77e0e76851d460073e64ea06d9c104194
CONTRACT_CREDIT_SCORE=0xc8ead4b26b2c6ac14c9fd90d9684c9bc2cc40085

# 仓单模块
CONTRACT_WAREHOUSE_CORE=0xd24180cc0fef2f3e545de4f9aafc09345cd08903
CONTRACT_WAREHOUSE_OPS=0x37a44585bf1e9618fdb4c62c4c96189a07dd4b48
CONTRACT_WAREHOUSE_CORE_EXT=0x55b63f96d81f094729af702adfc7af72bd75c54e

# 应收款模块
CONTRACT_RECEIVABLE_CORE=0x0102e8b6fc8cdf9626fddc1c3ea8c1e79b3fce94
CONTRACT_RECEIVABLE_REPAYMENT=0x33e56a083e135936c1144960a708c43a661706c0

# 物流模块
CONTRACT_LOGISTICS_CORE=0x6546c3571f17858ea45575e7c6457dad03e53dbb
CONTRACT_LOGISTICS_OPS=0xcceef68c9b4811b32c75df284a1396c7c5509561

# 贷款模块
CONTRACT_LOAN_CORE=0x19a6434154de51c7a7406edf312f01527441b561
CONTRACT_LOAN_REPAYMENT=0x745d4de0cf93b7d1db8dd8892daf05ac745766ce

# ==================== Java 调优配置 ====================
# 各服务 JVM 内存配置
JAVA_OPTS_AUTH=-Xms512m -Xmx512m -XX:+UseG1GC
JAVA_OPTS_ENTERPRISE=-Xms512m -Xmx512m -XX:+UseG1GC
JAVA_OPTS_WAREHOUSE=-Xms512m -Xmx512m -XX:+UseG1GC
JAVA_OPTS_LOGISTICS=-Xms512m -Xmx512m -XX:+UseG1GC
JAVA_OPTS_FINANCE=-Xms768m -Xmx768m -XX:+UseG1GC
JAVA_OPTS_CREDIT=-Xms512m -Xmx512m -XX:+UseG1GC
JAVA_OPTS_FISCO_GATEWAY=-Xms1g -Xmx1g -XX:+UseG1GC -XX:MaxGCPauseMillis=200

# ==================== Nginx 配置 ====================
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
