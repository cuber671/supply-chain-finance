# ============================================================
# Nginx 环境变量配置
# ============================================================
# 复制此文件为 .env.nginx 并修改相应值
# ============================================================

# Nginx HTTP 端口
NGINX_HTTP_PORT=80

# Nginx HTTPS 端口
NGINX_HTTPS_PORT=443

# SSL证书路径（相对于nginx目录）
SSL_CERT_PATH=./ssl/server.crt
SSL_KEY_PATH=./ssl/server.key

# 限流配置
RATE_LIMIT_GLOBAL=200r/s
RATE_LIMIT_AUTH=50r/s
RATE_LIMIT_ENTERPRISE=100r/s
RATE_LIMIT_WAREHOUSE=100r/s
RATE_LIMIT_LOGISTICS=100r/s
RATE_LIMIT_FINANCE=80r/s
RATE_LIMIT_CREDIT=80r/s
RATE_LIMIT_BLOCKCHAIN=30r/s

# 超时配置（秒）
PROXY_CONNECT_TIMEOUT=10
PROXY_SEND_TIMEOUT=30
PROXY_READ_TIMEOUT=30
PROXY_READ_TIMEOUT_BLOCKCHAIN=300

# 连接数限制
MAX_CONNECTIONS_PER_IP=50
MAX_CONNECTIONS_BLOCKCHAIN=20
